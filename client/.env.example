# Backend API URL (do NOT include a trailing slash or /api suffix)
# Development: leave blank (Vite proxy handles /api → localhost:3001)
# Production:  the subdomain root up to the app path prefix
#              e.g. https://sasmit.sachivalaya.com/gunaso
#              API calls will be appended as /api/submissions etc.
VITE_API_BASE_URL=

# Azure Entra External ID — same values for all parliamentarian branches
VITE_ENTRA_CLIENT_ID=your-entra-app-client-id
VITE_ENTRA_AUTHORITY=https://login.microsoftonline.com/your-entra-tenant-id
VITE_ENTRA_API_SCOPE=api://your-entra-app-client-id/access_as_user

# Subdomain of the parliamentarian this build is for — used to set the
# X-Tenant-Subdomain header in local development.
# In production this is derived from the branch name in CI (parl/<subdomain>).
# Example: abc
VITE_TENANT_SUBDOMAIN=your-parliamentarian-subdomain
