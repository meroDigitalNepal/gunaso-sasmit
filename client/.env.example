# Azure Entra External ID — same values for all parliamentarian branches
VITE_ENTRA_CLIENT_ID=your-entra-app-client-id
VITE_ENTRA_AUTHORITY=https://login.microsoftonline.com/your-entra-tenant-id
VITE_ENTRA_API_SCOPE=api://your-entra-app-client-id/access_as_user

# Subdomain of the MP this build is for — used to set the
# X-Tenant-Subdomain header in local development.
# In production this is derived from the branch name in CI (mp/<subdomain>).
# Example: john
VITE_TENANT_SUBDOMAIN=your-mp-subdomain
