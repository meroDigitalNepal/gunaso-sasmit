# PostgreSQL connection string (Azure Flexible Server)
DATABASE_URL=postgresql://user:password@host.postgres.database.azure.com:5432/gunaso?sslmode=require

# Azure Entra — same values for all MP branches
ENTRA_TENANT_ID=your-entra-tenant-id
ENTRA_CLIENT_ID=your-entra-app-client-id

# UUID from the mps table — set per branch/deployment
MP_ID=your-mp-uuid

# Allowed CORS origin — set per branch/deployment
# Development: http://localhost:5173
# Production:  https://<subdomain>.sachivalaya.org
CORS_ORIGIN=http://localhost:5173

# Microsoft Graph app registration for sending confirmation emails (app-only /
# client-credentials auth). Separate app from ENTRA_CLIENT_ID — that one only
# validates staff SPA tokens. Same values for all MP branches; reuses
# ENTRA_TENANT_ID since it's the same Entra tenant, just a different app.
GRAPH_CLIENT_ID=your-graph-mail-app-client-id
GRAPH_CLIENT_SECRET=your-graph-mail-app-client-secret

# Mailbox confirmation emails are sent from — same for all MP branches.
MAIL_SENDER_ADDRESS=noreply@yourdomain.org

# Canonical public URL citizens are directed to, used to build the tracking
# link in confirmation emails. Set per branch/deployment.
# Development: http://localhost:5173
# Production:  https://<subdomain>.sachivalaya.org/gunaso
PUBLIC_APP_URL=http://localhost:5173

PORT=3001
NODE_ENV=development
