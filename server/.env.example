# PostgreSQL connection string (Azure Flexible Server)
DATABASE_URL=postgresql://user:password@host.postgres.database.azure.com:5432/gunaso?sslmode=require

# Azure Entra — same values for all MP branches
ENTRA_TENANT_ID=your-entra-tenant-id
ENTRA_CLIENT_ID=your-entra-app-client-id

# UUID from the mps table — set per branch/deployment
MP_ID=your-mp-uuid

# Allowed CORS origin — set per branch/deployment
# Development: http://localhost:5173
# Production:  https://<subdomain>.sachivalaya.org
CORS_ORIGIN=http://localhost:5173

PORT=3001
NODE_ENV=development
